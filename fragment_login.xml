<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <!-- Full-screen gradient background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/login_bg_gradient" />

    <!-- Decorative circles -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-100dp"
        android:background="@drawable/bg_circle_glow_gold"
        android:alpha="0.3" />

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="200dp"
        android:layout_marginStart="-60dp"
        android:background="@drawable/bg_circle_glow_teal"
        android:alpha="0.2" />

    <!-- Main scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="80dp"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal">

            <!-- Logo + Title Section -->
            <LinearLayout
                android:id="@+id/logo_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <!-- App Icon with glow -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">

                    <View
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_logo_glow" />

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_app_logo"
                        android:scaleType="fitCenter" />
                </FrameLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/login_title"
                android:textColor="@color/text_primary_dark"
                android:textSize="36sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="-0.02"
                android:gravity="center" />

            <TextView
                android:id="@+id/subtitle_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/login_subtitle"
                android:textColor="@color/brand_gold"
                android:textSize="16sp"
                android:letterSpacing="0.05"
                android:gravity="center" />

            <!-- ═══ NFC Card ═══ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/nfc_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                app:cardBackgroundColor="#1A1E2E"
                app:cardCornerRadius="28dp"
                app:strokeColor="#FFFFFF20"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <!-- NFC Animation rings -->
                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:gravity="center">

                        <!-- Pulse rings -->
                        <View
                            android:id="@+id/nfc_pulse_ring"
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:layout_gravity="center"
                            android:background="@drawable/nfc_pulse_ring" />

                        <View
                            android:id="@+id/nfc_pulse_ring2"
                            android:layout_width="110dp"
                            android:layout_height="110dp"
                            android:layout_gravity="center"
                            android:background="@drawable/nfc_pulse_ring" />

                        <!-- NFC Icon center -->
                        <FrameLayout
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:layout_gravity="center"
                            android:background="@drawable/nfc_icon_bg">

                            <ImageView
                                android:id="@+id/nfc_icon"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_nfc"
                                app:tint="@color/brand_gold" />
                        </FrameLayout>

                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="@string/login_nfc_title"
                        android:textColor="@color/text_primary_dark"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/nfc_status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/login_nfc_instruction"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.5"
                        android:fontFamily="sans-serif" />

                    <ProgressBar
                        android:id="@+id/nfc_progress_bar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:visibility="gone"
                        android:indeterminateTint="@color/brand_gold" />

                    <Button
                        android:id="@+id/enable_nfc_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/login_enable_nfc"
                        android:backgroundTint="@color/brand_gold"
                        android:textColor="@color/dark_bg_primary"
                        android:visibility="gone"
                        style="@style/Widget.Material3.Button"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#FFFFFF20" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:text="أو"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="14sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#FFFFFF20" />
            </LinearLayout>

            <!-- Alt Login Buttons -->
            <LinearLayout
                android:id="@+id/alt_login_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:weightSum="2">

                <!-- Biometric -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/biometric_btn"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#1A1E2E"
                    app:cardCornerRadius="18dp"
                    app:strokeColor="#FFFFFF20"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_fingerprint"
                            app:tint="@color/brand_teal" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="بصمة"
                            android:textColor="@color/text_secondary_dark"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- PIN -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/pin_btn"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="#1A1E2E"
                    app:cardCornerRadius="18dp"
                    app:strokeColor="#FFFFFF20"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_pin"
                            app:tint="@color/brand_blue" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="PIN"
                            android:textColor="@color/text_secondary_dark"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Version -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="سمارت كربلاء v1.0 | وزارة الداخلية العراقية"
                android:textColor="@color/text_hint_dark"
                android:textSize="11sp"
                android:gravity="center" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
